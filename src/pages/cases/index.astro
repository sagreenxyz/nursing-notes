---
import Layout from '../../layouts/Layout.astro';
import { cases } from '../../data/cases';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;

const categories = [...new Set(cases.map(c => c.category))];

const difficultyColor: Record<string, string> = {
  Beginner: '#27ae60',
  Intermediate: '#e67e22',
  Advanced: '#c0392b',
};
---

<Layout title="All Cases" description="Browse all clinical nursing case studies with unfolding scenarios and professional nursing notes.">
  <div class="page-header">
    <h1>All Clinical Cases</h1>
    <p>Browse our library of unfolding clinical case studies. Each case includes multiple phases and professional nursing documentation.</p>
  </div>

  {categories.map(cat => (
    <section class="category-section">
      <h2 class="category-title">{cat}</h2>
      <div class="cases-list">
        {cases.filter(c => c.category === cat).map(c => (
          <a href={`${base}/cases/${c.slug}/`} class="case-row">
            <div class="case-row-main">
              <h3>{c.title}</h3>
              <p class="subtitle">{c.subtitle}</p>
              <p class="summary">{c.summary}</p>
              <div class="tags">
                {c.tags.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
            <div class="case-row-side">
              <span class="difficulty-badge" style={`background:${difficultyColor[c.difficulty]};`}>{c.difficulty}</span>
              <span class="phases-info">{c.phases} phases</span>
              <span class="read-link">Read →</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  ))}
</Layout>

<style>
  .page-header { margin-bottom: 2.5rem; }
  .page-header h1 { font-size: 2rem; font-weight: 800; color: #1a5276; margin-bottom: 0.5rem; }
  .page-header p { color: #566573; font-size: 1rem; }

  .category-section { margin-bottom: 2.5rem; }
  .category-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #148f77;
    border-left: 4px solid #148f77;
    padding-left: 0.75rem;
    margin-bottom: 1rem;
  }
  .cases-list { display: flex; flex-direction: column; gap: 1rem; }

  .case-row {
    display: flex;
    gap: 1.5rem;
    background: white;
    border: 1px solid #e8ecef;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 2px 6px rgba(0,0,0,.06);
    text-decoration: none;
    color: inherit;
    transition: transform .2s, box-shadow .2s;
    align-items: flex-start;
  }
  .case-row:hover { transform: translateX(4px); box-shadow: 0 4px 14px rgba(0,0,0,.1); text-decoration: none; }
  .case-row-main { flex: 1; }
  .case-row-main h3 { font-size: 1.05rem; font-weight: 700; color: #1a5276; margin-bottom: 0.2rem; }
  .subtitle { font-size: 0.83rem; color: #2980b9; font-style: italic; margin-bottom: 0.4rem; }
  .summary { font-size: 0.86rem; color: #566573; line-height: 1.5; margin-bottom: 0.6rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .tag { background: #eaf4fc; color: #1a5276; font-size: 0.75rem; padding: 0.18rem 0.5rem; border-radius: 10px; border: 1px solid #aed6f1; }

  .case-row-side {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    min-width: 100px;
    flex-shrink: 0;
  }
  .difficulty-badge { font-size: 0.75rem; font-weight: 700; color: white; padding: 0.25rem 0.65rem; border-radius: 12px; }
  .phases-info { font-size: 0.78rem; color: #7f8c8d; }
  .read-link { font-size: 0.9rem; font-weight: 700; color: #2980b9; }

  @media (max-width: 540px) {
    .case-row { flex-direction: column; }
    .case-row-side { flex-direction: row; align-items: center; }
  }
</style>
